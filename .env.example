# ===========================================
# Trip Assistant — Environment Variables
# ===========================================

# --- Database ---
DATABASE_URL=postgresql://tripuser:trippass@localhost:5432/tripdb
POSTGRES_USER=tripuser
POSTGRES_PASSWORD=trippass
POSTGRES_DB=tripdb

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=random-webhook-secret
TELEGRAM_BOT_USERNAME=your-bot-username

# --- Google Gemini AI ---
GEMINI_API_KEY=AIzaSy-your-gemini-key

# --- OpenAI (Whisper voice recognition) ---
OPENAI_API_KEY=sk-your-openai-key

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# --- Sentry ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- App Config ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Apple Wallet (optional, required for .pkpass ticket export) ---
APPLE_WALLET_WWDR_BASE64=
APPLE_WALLET_SIGNER_CERT_BASE64=
APPLE_WALLET_SIGNER_KEY_BASE64=
APPLE_WALLET_SIGNER_KEY_PASSPHRASE=
APPLE_WALLET_PASS_TYPE_IDENTIFIER=
APPLE_WALLET_TEAM_IDENTIFIER=
APPLE_WALLET_ORGANIZATION_NAME=Trip Assistant
