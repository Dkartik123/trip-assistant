{
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "app/src/**/*.{ts,tsx}": [
      "app/node_modules/.bin/prettier --write",
      "app/node_modules/.bin/eslint --config app/eslint.config.mjs --fix"
    ]
  }
}
